{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["@playwright/test", "node"]
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "eslint.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}